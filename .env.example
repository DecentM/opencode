# How would you like to be called?
MY_NAME=

# Enable Slack integration for reading messages and channel communication.
FEATURE_SLACK=true
# https://github.com/korotovsky/slack-mcp-server/blob/d25fa862f30bc235394e76788576ac44d09227e4/docs/01-authentication-setup.md#option-1-using-slack_mcp_xoxc_tokenslack_mcp_xoxd_token-browser-session
# Follow the instructions from this link, using Option 1 (Browser session)
SLACK_MCP_XOXC_TOKEN=
SLACK_MCP_XOXD_TOKEN=
# Open a channel, click the three dots on the top right, Copy > Copy Link. Paste the last part (after the last /) in here.
# Comma separated list, if you want to add more. Leave empty to disallow the agent from sending Slack messages.
SLACK_MCP_ALLOWED_CHANNELS=

# Enable GitHub integration for repository operations, issues, and pull requests.
FEATURE_GITHUB=true
# Your GitHub personal access token. Create one at https://github.com/settings/tokens/new
# Minimum scopes:
#   repo - Repository operations
#   read:packages - Docker image access
#   read:org - Organization team access
# For full functionality, read https://github.com/github/github-mcp-server
GITHUB_TOKEN=

# Enable Figma integration for reading design files and extracting design tokens.
FEATURE_FIGMA=true
# Your Figma Personal Access Token. Create one at:
#   Figma → Click your name (top left) → Settings → Security → Personal access tokens
# Required scope:
#   file_content:read - Read file contents
# See: https://help.figma.com/hc/en-us/articles/8085703771159-Manage-personal-access-tokens
FIGMA_TOKEN=

# Enable web scraping capabilities using Playwright and FlareSolverr.
# Allows the agent to browse websites, extract content, and interact with web pages.
FEATURE_WEB_SCRAPING=true
# Only has any effect if FEATURE_WEB_SCRAPING is true. Enables the usage of an authenticated
# browser with no UI (runs in background, shares state with visible browser).
# Set to true to allow the agent to browse on your behalf without seeing the browser.
FEATURE_WEB_SCRAPING_HEADLESS=false

# Enable Jira integration for issue tracking and project management.
# Requires authentication via "bin/opencode.sh mcp auth" after enabling.
FEATURE_JIRA=true

# Enable Notion integration for reading and writing documentation.
# Requires authentication via "bin/opencode.sh mcp auth" after enabling.
FEATURE_NOTION=true

# Enable Sentry integration for access to hosted Sentry errors.
# Requires authentication via "bin/opencode.sh mcp auth" after enabling.
FEATURE_SENTRY=true

# Architect makes plans about code structure and organisation
# Major permissions: file read, internet access, jira RO, notion RO, slack RO, figma RO
DISABLE_ARCHITECT=false

# Coder implements code changes and runs tests
# Major permissions: file read/write, shell execution
DISABLE_CODER=false

# Communicator writes docs and updates Jira/Notion/Slack
# Major permissions: file read, internet access, jira RW, notion RW, slack RW
DISABLE_COMMUNICATOR=false

# DevOps manages CI/CD, containers, and infrastructure changes
# Major permissions: file read/write, shell execution, internet access
DISABLE_DEVOPS=false

# Explore inspects the codebase read-only to answer structure questions
# Major permissions: file read
DISABLE_EXPLORE=false

# Git handles git operations, history, and repo hygiene workflows
# Major permissions: file read/write, shell execution
DISABLE_GIT=false

# GNS banks and retrieves long-term project/user knowledge
# Major permissions: gns access
DISABLE_GNS=false

# Math performs calculations and numerical analysis
# Major permissions: shell execution
DISABLE_MATH=false

# Personal assistant automates browser-based tasks (bookings, accounts, Google Workspace)
# Major permissions: internet access, browser automation
DISABLE_PERSONAL_ASSISTANT=false

# Researcher gathers info from the web and transforms data
# Major permissions: file read, internet access, browser automation, shell execution
DISABLE_RESEARCHER=false

# Reviewer audits code quality, security, and correctness (read-only)
# Major permissions: file read
DISABLE_REVIEWER=false

# Run "bin/opencode.sh mcp auth" to log into remote MCP servers after filling this file out!
# Each time you run this command, select a different MCP server that shows "not authenticated"
