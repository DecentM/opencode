{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "autoupdate": false,
  "snapshot": true,
  "logLevel": "WARN",
  "default_agent": "coordinator",
  "keybinds": {},
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": false
    },
    "diff_style": "auto"
  },
  "theme": "chess-com",

  "username": "{env:MY_NAME}",
  "small_model": "github-copilot/claude-haiku-4.5",
  "enabled_providers": ["github-copilot", "openai", "anthropic"],
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },

  "share": "disabled",
  "permission": {
    "*": "deny"
  },
  "instructions": [
    "{env:OPENCODE_CONFIG_DIR}/rules/all.md",
    "{env:PWD}/AGENTS.md",
    "{env:PWD}/.cursor/rules/*.{md,mdx}"
  ],
  "agent": {
    "general": {
      "disable": true
    },
    "summary": {
      "disable": true
    },
    "title": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "writer": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true,
    },
    "architect": {
      "disable": {env:DISABLE_ARCHITECT}
    },
    "coder": {
      "disable": {env:DISABLE_CODER}
    },
    "communicator": {
      "disable": {env:DISABLE_COMMUNICATOR}
    },
    "devops": {
      "disable": {env:DISABLE_DEVOPS}
    },
    "explore": {
      "disable": {env:DISABLE_EXPLORE}
    },
    "git": {
      "disable": {env:DISABLE_GIT}
    },
    "gns": {
      "disable": {env:DISABLE_GNS}
    },
    "math": {
      "disable": {env:DISABLE_MATH}
    },
    "personal-assistant": {
      "disable": {env:DISABLE_PERSONAL_ASSISTANT}
    },
    "researcher": {
      "disable": {env:DISABLE_RESEARCHER}
    },
    "reviewer": {
      "disable": {env:DISABLE_REVIEWER}
    }
  },
  "mcp": {
    "sequentialthinking": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--network=none",
        "--memory=512m",
        "--cpus=1",
        "mcp/sequentialthinking"
      ],
      "enabled": true
    },

    "time": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--network=none",
        "--memory=512m",
        "--cpus=1",
        "mcp/time"
      ],
      "enabled": true
    },

    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "enabled": {env:FEATURE_GITHUB},
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },

    "flaresolverr": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "docker run --rm -i --init --shm-size=2g --memory=2g --cpus=2 chess-opencode-flaresolverr"
      ],
      "enabled": {env:FEATURE_WEB_SCRAPING}
    },

    "playwright-headed": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "docker run --rm -i --init --user root --shm-size=2g --memory=2g --cpus=2 -v opencode-playwright-output:/data/output -v opencode-playwright-userdata:/data/userdata -e PLAYWRIGHT_MCP_OUTPUT_DIR=/data/output -e PLAYWRIGHT_HEADLESS=false -e WAYLAND_DISPLAY=$WAYLAND_DISPLAY -e XDG_RUNTIME_DIR=/run/user/$(id -u) -e XDG_SESSION_TYPE=wayland -e DISPLAY=$DISPLAY -e XAUTHORITY=/tmp/.Xauthority -v ${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}:/run/user/$(id -u)/${WAYLAND_DISPLAY}:rw -v /tmp/.X11-unix:/tmp/.X11-unix:rw -v ${HOME}/.Xauthority:/tmp/.Xauthority:ro --device /dev/dri:/dev/dri chess-opencode-playwright"
      ],
      "enabled": {env:FEATURE_WEB_SCRAPING}
    },

    "playwright-headless": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "docker run --rm -i --init --user root --shm-size=1g --memory=1g --cpus=1 -v opencode-playwright-output:/data/output -v opencode-playwright-userdata:/data/userdata -e PLAYWRIGHT_MCP_OUTPUT_DIR=/data/output -e PLAYWRIGHT_HEADLESS=true chess-opencode-playwright"
      ],
      "enabled": {env:FEATURE_WEB_SCRAPING_HEADLESS}
    },

    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": {env:FEATURE_JIRA}
    },

    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": {env:FEATURE_NOTION}
    },

    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": {env:FEATURE_SENTRY}
    },

    "slack": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--memory=512m",
        "--cpus=1",
        "-e",
        "SLACK_MCP_XOXC_TOKEN={env:SLACK_MCP_XOXC_TOKEN}",
        "-e",
        "SLACK_MCP_XOXD_TOKEN={env:SLACK_MCP_XOXD_TOKEN}",
        "-e",
        "SLACK_MCP_ADD_MESSAGE_TOOL={env:SLACK_MCP_ALLOWED_CHANNELS}",
        "ghcr.io/korotovsky/slack-mcp-server",
        "mcp-server",
        "--transport",
        "stdio"
      ],
      "enabled": {env:FEATURE_SLACK}
    },

    "figma": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--network=bridge",
        "--memory=2g",
        "--cpus=1",
        "-e",
        "FIGMA_API_KEY={env:FIGMA_TOKEN}",
        "chess-opencode-figma"
      ],
      "enabled": {env:FEATURE_FIGMA}
    },
  }
}
